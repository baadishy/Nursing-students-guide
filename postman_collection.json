{
  "info": {
    "_postman_id": "a7e7e6e5-2c8c-4a3d-9c3f-9d9d8d6d6d6d",
    "name": "Nursing App Admin Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "name": "Admin User",
            "grade": "NA",
            "governorate": "NA",
            "classNumber": "NA",
            "schoolName": "NA",
            "role": "admin",
            "password": "your_secure_password"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "signup"]
        }
      },
      "response": []
    },
    {
      "name": "Login as Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": {
            "id": "your_admin_id",
            "name": "Admin User",
            "password": "your_secure_password"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ]
}
